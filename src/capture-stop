#!/usr/bin/python3
"""Floating stop-recording button. Blocks until Stop is clicked.
Usage: capture-stop "Label"
"""
import sys, platform


def run_gtk(label):
    import gi
    gi.require_version('Gtk', '3.0')
    from gi.repository import Gtk, Gdk

    class StopButton(Gtk.Window):
        def __init__(self, label):
            super().__init__(type=Gtk.WindowType.TOPLEVEL)
            self.set_decorated(False)
            self.set_keep_above(True)
            self.set_skip_taskbar_hint(True)
            self.set_default_size(260, 88)

            display = Gdk.Display.get_default()
            root = Gdk.get_default_root_window()
            _, cx, cy, _ = root.get_pointer()
            monitor = display.get_monitor_at_point(cx, cy)
            geo = monitor.get_geometry()
            self.move(geo.x + geo.width - 280, geo.y + 20)

            visual = self.get_screen().get_rgba_visual()
            if visual:
                self.set_visual(visual)
            self.set_app_paintable(True)
            self.connect('delete-event', lambda *_: True)
            self.connect('draw', self._draw)
            self._build(label)
            self._css()

        def _build(self, label):
            vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
            self.add(vbox)
            title = Gtk.Label()
            title.set_markup(f'<span color="#f38ba8" weight="bold" size="large">🔴  {label}</span>')
            title.set_margin_top(14)
            title.set_margin_bottom(8)
            vbox.pack_start(title, False, False, 0)
            btn = Gtk.Button(label='⏹   Stop Recording')
            btn.set_margin_start(18)
            btn.set_margin_end(18)
            btn.set_margin_bottom(14)
            btn.connect('clicked', lambda *_: Gtk.main_quit())
            vbox.pack_start(btn, False, False, 0)

        def _draw(self, widget, cr):
            a = widget.get_allocation()
            cr.set_source_rgba(0.118, 0.118, 0.180, 0.96)
            cr.rectangle(0, 0, a.width, a.height); cr.fill()
            cr.set_line_width(2.5)
            cr.set_source_rgba(0.953, 0.545, 0.659, 1.0)
            cr.rectangle(1.25, 1.25, a.width-2.5, a.height-2.5); cr.stroke()
            return False

        def _css(self):
            css = b"""
            window { background-color: rgba(0,0,0,0); }
            button {
                background-color: #3d2030; color: #f38ba8;
                border: 1px solid #f38ba8; border-radius: 8px; padding: 7px 14px;
            }
            button:hover { background-color: #f38ba8; color: #1e1e2e; }
            """
            p = Gtk.CssProvider()
            p.load_from_data(css)
            Gtk.StyleContext.add_provider_for_screen(
                self.get_screen(), p, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    win = StopButton(label)
    win.show_all()
    Gtk.main()


def run_mac(label):
    import tkinter as tk

    root = tk.Tk()
    root.overrideredirect(True)
    root.wm_attributes('-topmost', True)

    win_w, win_h = 260, 88
    sw = root.winfo_screenwidth()
    root.geometry(f'{win_w}x{win_h}+{sw - win_w - 20}+20')
    root.configure(bg='#181825')

    # Border via canvas underneath
    border = tk.Canvas(root, bg='#181825', highlightthickness=0)
    border.place(x=0, y=0, relwidth=1, relheight=1)
    border.create_rectangle(1, 1, win_w-2, win_h-2, outline='#f38ba8', width=2)

    tk.Label(
        root, text=f'🔴  {label}',
        bg='#181825', fg='#f38ba8',
        font=('Helvetica', 14, 'bold')
    ).pack(pady=(14, 6))

    tk.Button(
        root, text='⏹  Stop Recording',
        bg='#3d2030', fg='#f38ba8',
        activebackground='#f38ba8', activeforeground='#1e1e2e',
        relief='flat', padx=14, pady=7,
        font=('Helvetica', 12), cursor='hand2',
        command=root.quit
    ).pack(padx=18, pady=(0, 14), fill='x')

    root.mainloop()


if __name__ == '__main__':
    label = ' '.join(sys.argv[1:]) if len(sys.argv) > 1 else 'Recording'
    if platform.system() == 'Darwin':
        run_mac(label)
    else:
        run_gtk(label)
