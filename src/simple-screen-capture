#!/usr/bin/env bash
# simple-screen-capture — screenshot · GIF · screencast with GTK capture menu

set -uo pipefail

export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

CONFIG_DIR="$HOME/.config/capture"
SCREENSHOTS_DIR="$HOME/Pictures/Screenshots"
SCREENCASTS_DIR="$HOME/Videos/Screencasts"
SLICES_DIR="$SCREENSHOTS_DIR/slices"

mkdir -p "$CONFIG_DIR" "$SCREENSHOTS_DIR" "$SCREENCASTS_DIR"

# ── dependency check ──────────────────────────────────────────────────────────
MISSING=()
for cmd in maim ffmpeg xclip optipng; do
  command -v "$cmd" &>/dev/null || MISSING+=("$cmd")
done
if (( ${#MISSING[@]} )); then
  MSG="capture: missing ${MISSING[*]} — install: sudo apt install ${MISSING[*]}"
  command -v notify-send &>/dev/null && notify-send "capture" "$MSG" -t 6000
  echo "$MSG" >&2
  exit 1
fi

# ── notify helper ─────────────────────────────────────────────────────────────
say() { command -v notify-send &>/dev/null && notify-send "$1" "$2" -t "${3:-3000}" || true; }

# ── stop panel ────────────────────────────────────────────────────────────────
wait_for_stop() {
  sleep 0.4
  /usr/bin/python3 /usr/bin/capture-stop "$1"
}

# ── smart slice ───────────────────────────────────────────────────────────────
do_smart_slice() {
  local video="$1"
  local ts="$2"
  local threshold="${3:-0.07}"
  local outdir="$SLICES_DIR/$ts"
  mkdir -p "$outdir"

  say "Smart Slice" "Analysing recording…" 20000

  # 0.07 threshold suits UI/terminal recordings (movie scene cuts need ~0.25+).
  # The gte(t-prev_selected_t,0.5) guard prevents frame bursts during rapid
  # output — at most one slice every 0.5 s even if every frame is "different".
  ffmpeg -i "$video" \
    -vf "select='eq(n\,0)+gt(scene\,${threshold})*gte(t-prev_selected_t\,0.5)',setpts=N/TB" \
    -vsync vfr \
    -q:v 2 \
    "$outdir/slice_%04d.png" \
    -loglevel quiet 2>/dev/null

  local count
  count=$(find "$outdir" -name 'slice_*.png' 2>/dev/null | wc -l)

  if (( count == 0 )); then
    # Fallback: just grab first frame if nothing was detected
    ffmpeg -i "$video" -frames:v 1 "$outdir/slice_0001.png" -loglevel quiet 2>/dev/null || true
    count=1
  fi

  say "Smart Slice" "${count} screenshot$([ "$count" -ne 1 ] && echo s) saved → slices/${ts}" 8000
}

# ── screenshot ────────────────────────────────────────────────────────────────
do_screenshot() {
  local clipboard_mode="$1"
  local tmp ts out
  tmp=$(mktemp /tmp/capture-XXXXXX.png)
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENSHOTS_DIR/${ts}.png"
  trap 'rm -f "$tmp"' RETURN

  local rfile; rfile=$(mktemp /tmp/capture-region-XXXXXX)
  trap 'rm -f "$rfile"' RETURN
  local last_args=(); [[ -f "$CONFIG_DIR/last_region_screenshot" ]] && read -ra last_args < "$CONFIG_DIR/last_region_screenshot"
  /usr/bin/python3 /usr/bin/capture-region screenshot "${last_args[@]}" > "$rfile"
  local region; region=$(cat "$rfile")
  [[ -z "$region" ]] && return
  local X Y W H; read -r X Y W H <<< "$region"
  echo "$X $Y $W $H" > "$CONFIG_DIR/last_region_screenshot"

  maim -g "${W}x${H}+${X}+${Y}" "$tmp" 2>/dev/null || return

  local orig comp pct
  orig=$(wc -c < "$tmp")
  optipng -quiet -o2 "$tmp"
  comp=$(wc -c < "$tmp")
  pct=$(( (orig - comp) * 100 / orig ))

  cp "$tmp" "$out"

  if [[ "$clipboard_mode" == "base64" ]]; then
    base64 -w 0 "$tmp" | xclip -selection clipboard
    say "Screenshot" "Base64 copied — ${comp}B (−${pct}%)"
  else
    xclip -selection clipboard -t image/png < "$tmp"
    say "Screenshot" "Image copied — ${comp}B (−${pct}%)"
  fi
}

# ── gif ───────────────────────────────────────────────────────────────────────
do_gif() {
  local smart_slice="$1"
  local threshold="$2"
  local tmp palette ts out
  tmp=$(mktemp /tmp/capture-XXXXXX.mp4)
  palette=$(mktemp /tmp/capture-XXXXXX.png)
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENCASTS_DIR/${ts}.gif"

  local rfile; rfile=$(mktemp /tmp/capture-region-XXXXXX)
  trap 'rm -f "$rfile"' RETURN
  local last_args=(); [[ -f "$CONFIG_DIR/last_region_gif" ]] && read -ra last_args < "$CONFIG_DIR/last_region_gif"
  /usr/bin/python3 /usr/bin/capture-region gif "${last_args[@]}" > "$rfile"
  local region; region=$(cat "$rfile")
  [[ -z "$region" ]] && return
  local X Y W H; read -r X Y W H <<< "$region"
  echo "$X $Y $W $H" > "$CONFIG_DIR/last_region_gif"
  [[ $W -lt 2 || $H -lt 2 ]] && return

  ffmpeg -f x11grab -r 15 -s "${W}x${H}" -i "${DISPLAY}+${X},${Y}" \
    -vcodec libx264 -preset ultrafast -crf 0 "$tmp" -y -loglevel quiet &
  local fpid=$!

  wait_for_stop "Recording GIF"
  kill "$fpid" 2>/dev/null; wait "$fpid" 2>/dev/null || true

  say "Capture" "Converting to GIF…" 30000

  ffmpeg -i "$tmp" \
    -vf "fps=15,scale=${W}:-1:flags=lanczos,palettegen=stats_mode=diff" \
    "$palette" -y -loglevel quiet

  ffmpeg -i "$tmp" -i "$palette" \
    -filter_complex "fps=15,scale=${W}:-1:flags=lanczos[x];[x][1:v]paletteuse=dither=bayer:bayer_scale=5:diff_mode=rectangle" \
    "$out" -y -loglevel quiet

  # Smart slice runs before temp file cleanup
  [[ "$smart_slice" == "1" ]] && do_smart_slice "$tmp" "$ts" "$threshold"

  rm -f "$tmp" "$palette"

  local size; size=$(du -h "$out" | cut -f1)
  say "GIF saved" "${size} — $(basename "$out")" 5000
}

# ── screencast ────────────────────────────────────────────────────────────────
do_record() {
  local audio="$1"
  local smart_slice="$2"
  local threshold="$3"
  local ts out
  ts=$(date +%Y-%m-%d_%H-%M-%S)
  out="$SCREENCASTS_DIR/${ts}.mp4"

  local label
  [[ "$audio" == "yes" ]] && label="Recording + Audio" || label="Recording Screen"

  local rfile; rfile=$(mktemp /tmp/capture-region-XXXXXX)
  trap 'rm -f "$rfile"' RETURN
  local last_args=(); [[ -f "$CONFIG_DIR/last_region_screen" ]] && read -ra last_args < "$CONFIG_DIR/last_region_screen"
  /usr/bin/python3 /usr/bin/capture-region "$audio" "${last_args[@]}" > "$rfile"
  local region; region=$(cat "$rfile")
  [[ -z "$region" ]] && return
  local X Y W H; read -r X Y W H <<< "$region"
  echo "$X $Y $W $H" > "$CONFIG_DIR/last_region_screen"
  [[ $W -lt 2 || $H -lt 2 ]] && return

  local -a args=(-f x11grab -r 30 -s "${W}x${H}" -i "${DISPLAY}+${X},${Y}")

  if [[ "$audio" == "yes" ]]; then
    local src
    src=$(pactl info 2>/dev/null | awk '/Default Source/{print $3}') || src="default"
    args+=(-f pulse -i "$src")
  fi

  args+=(-vcodec libx264 -preset ultrafast -crf 18)
  [[ "$audio" == "yes" ]] && args+=(-acodec aac -b:a 128k)
  args+=("$out" -y -loglevel quiet)

  ffmpeg "${args[@]}" &
  local fpid=$!

  wait_for_stop "$label"
  kill "$fpid" 2>/dev/null; wait "$fpid" 2>/dev/null || true

  local size; size=$(du -h "$out" | cut -f1)
  say "Screencast saved" "${size} — $(basename "$out")" 5000

  [[ "$smart_slice" == "1" ]] && do_smart_slice "$out" "$ts" "$threshold"
}

# ── setup mode ────────────────────────────────────────────────────────────────
do_setup() {
  echo "Setting up simple-screen-capture shortcut (Ctrl+Shift+Alt+R)..."

  gsettings set org.gnome.shell.keybindings show-screen-recording-ui "[]"
  echo "  GNOME screen-recording shortcut cleared"

  local xbrc="$HOME/.xbindkeysrc"

  # Remove any existing binding for this key (old 'capture' entry, duplicates, etc.)
  # A binding block is: one command line + one key line. We delete the command line
  # immediately preceding any line that mentions Control+Shift+Alt+r.
  if grep -qi 'Control+Shift+Alt+r' "$xbrc" 2>/dev/null; then
    # Use a temp file: drop every line N-1 where line N matches the key
    python3 - "$xbrc" <<'PY'
import sys, re
path = sys.argv[1]
lines = open(path).readlines()
key_pat = re.compile(r'Control\+Shift\+Alt\+r', re.IGNORECASE)
drop = set()
for i, ln in enumerate(lines):
    if key_pat.search(ln):
        drop.add(i)          # the key line itself
        # walk back to find the command line (skip blank/comment lines)
        j = i - 1
        while j >= 0 and (lines[j].strip() == '' or lines[j].strip().startswith('#')):
            j -= 1
        if j >= 0 and lines[j].strip().startswith('"'):
            drop.add(j)
        # also drop any comment line immediately before the command
        k = j - 1
        if k >= 0 and lines[k].strip().startswith('#'):
            drop.add(k)
kept = [ln for i, ln in enumerate(lines) if i not in drop]
# trim trailing blank lines then write
content = ''.join(kept).rstrip('\n') + '\n'
open(path, 'w').write(content)
PY
    echo "  xbindkeys: removed old binding(s) for Control+Shift+Alt+r"
  fi

  printf '\n# simple-screen-capture\n"/usr/bin/simple-screen-capture"\n  Control+Shift+Alt+r\n' >> "$xbrc"
  echo "  xbindkeys: binding added to $xbrc"

  local autostart="$HOME/.config/autostart/xbindkeys.desktop"
  mkdir -p "$(dirname "$autostart")"
  cat > "$autostart" << 'DESKTOP'
[Desktop Entry]
Type=Application
Name=xbindkeys
Exec=/usr/bin/capture-xbindkeys-start
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
DESKTOP
  echo "  autostart: $autostart"

  pkill xbindkeys 2>/dev/null || true
  sleep 0.2
  xbindkeys
  echo "  xbindkeys: started"

  echo ""
  echo "Done. Press Ctrl+Shift+Alt+R to open the capture menu."
}

# ── main ──────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--setup" ]]; then
  do_setup
  exit 0
fi

result=$(/usr/bin/python3 /usr/bin/capture-menu 2>/dev/null) || true
[[ -z "$result" ]] && exit 0

read -r action clipboard smart_slice threshold <<< "$result"

case "$action" in
  screenshot) do_screenshot "$clipboard" ;;
  gif)        do_gif           "$smart_slice" "$threshold" ;;
  screen)     do_record "no"   "$smart_slice" "$threshold" ;;
  audio)      do_record "yes"  "$smart_slice" "$threshold" ;;
esac
